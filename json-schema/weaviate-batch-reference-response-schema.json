{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://api-evangelist.github.io/weaviate/json-schema/weaviate-batch-reference-response-schema.json",
  "title": "BatchReferenceResponse",
  "description": "Weaviate BatchReferenceResponse schema",
  "allOf": [
    {
      "$ref": "#/components/schemas/BatchReference"
    },
    {
      "properties": {
        "result": {
          "format": "object",
          "description": "Results for this specific reference.",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "SUCCESS",
                "FAILED"
              ],
              "default": "SUCCESS"
            },
            "errors": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    }
  ]
}