  "title": "ShardStatusGetResponse",
  "description": "Response body of shard status get request",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the shard"
    },
    "status": {
      "type": "string",
      "description": "Status of the shard"
    },
    "vectorQueueSize": {
